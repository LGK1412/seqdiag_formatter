{
  "name": "seqdiag-formatter",
  "publisher": "kien",
  "displayName": "seqdiag_formatter",
  "description": "seqdiag-formatter",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:seqdiag"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seqdiag-formatter.helloWorld",
        "title": "Hello World"
      }
    ],
    "documentFormattingEditProviders": [
      {
        "language": "seqdiag"
      }
    ],
    "grammars": [
      {
        "language": "seqdiag",
        "scopeName": "source.seqdiag",
        "path": "./syntaxes/seqdiag.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LGK1412/seqdiag_formatter.git"
  },
  "license": "MIT"
}